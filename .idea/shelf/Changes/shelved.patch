<+><?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<!DOCTYPE topic SYSTEM \"https://resources.jetbrains.com/writerside/1.0/html-entities.dtd\">\n<topic xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\n       xsi:noNamespaceSchemaLocation=\"https://resources.jetbrains.com/writerside/1.0/topic.v2.xsd\"\n       title=\"Azure DevOps Pull Requests\" id=\"Welcome\">\n\n    <section-starting-page>\n        <title>%product%</title>\n        <description>\n            Review code, run AI-assisted reviews, and manage Azure DevOps pull requests without ever leaving your JetBrains IDE.\n        </description>\n\n        <spotlight>\n            <a href=\"Quick-Start.md\" type=\"start\"\n               summary=\"Sign in, open the tool window, and review your first PR in under a minute.\">Quick Start</a>\n            <a href=\"Installation.md\" type=\"install\"\n               summary=\"Install from the JetBrains Marketplace in any IntelliJ-based IDE.\">Installation</a>\n        </spotlight>\n\n        <primary>\n            <title>Key Features</title>\n            <a href=\"Pull-Requests.md\" type=\"branch\"\n               summary=\"Browse, filter, search, and create PRs from the tool window.\">Pull Requests</a>\n            <a href=\"Code-Review.md\" type=\"check-list\"\n               summary=\"Native diff viewer with inline comments, voting, and file-viewed tracking.\">Code Review</a>\n            <a href=\"Review-in-Editor.md\" type=\"documents\"\n               summary=\"Review threads overlaid on your normal editor when the PR's branch is checked out.\">Review in Editor</a>\n            <a href=\"Discussions-and-Comments.md\" type=\"community\"\n               summary=\"Threaded comments with markdown, @mentions, suggested edits, and image attachments.\">Discussions &amp; Comments</a>\n            <a href=\"Git-Integration.md\" type=\"integration\"\n               summary=\"Current-branch PR matching, status bar widget, and HTTPS credential handoff.\">Git Integration</a>\n            <a href=\"Statistics.md\" type=\"data\"\n               summary=\"Time-to-merge, vote distribution, and per-author counts in a dedicated editor tab.\">Statistics</a>\n        </primary>\n\n        <secondary>\n            <title>AI &amp; Configuration</title>\n            <a href=\"AI-Features.md\" type=\"idea\"\n               summary=\"PR summaries, AI-assisted code review, explain-code, and commit-message drafts.\">AI Features</a>\n            <a href=\"Privacy-and-Data.md\" type=\"lock\"\n               summary=\"What's sent to Azure DevOps and AI providers, and how to keep everything local.\">Privacy &amp; Data</a>\n            <a href=\"Authentication.md\" type=\"key\"\n               summary=\"Personal Access Token or Microsoft Entra ID OAuth, multi-account support.\">Authentication</a>\n            <a href=\"Settings.md\" type=\"settings\"\n               summary=\"Accounts, AI providers, notifications, and keymap.\">Settings</a>\n            <a href=\"Keyboard-Shortcuts.md\" type=\"keyboard\"\n               summary=\"Every action with its action ID and default binding.\">Keyboard Shortcuts</a>\n        </secondary>\n\n        <misc>\n            <cards>\n                <title>Help</title>\n                <a href=\"Troubleshooting.md\" type=\"bug\"\n                   summary=\"Common errors, fixes, and how to file a bug.\">Troubleshooting</a>\n                <a href=\"FAQ.md\" type=\"support\"\n                   summary=\"Decision-style questions: on-prem support, AI privacy, OAuth vs PAT.\">FAQ</a>\n            </cards>\n\n            <cards narrow=\"true\">\n                <title>Off-site</title>\n                <a href=\"%marketplace_url%\" type=\"library\"\n                   summary=\"Install the plugin, browse version history, and read user reviews.\">JetBrains Marketplace</a>\n                <a href=\"%repo_url%\" type=\"open-source\"\n                   summary=\"Documentation source — file issues for typos, missing content, or broken links.\">GitHub repository</a>\n            </cards>\n        </misc>\n\n    </section-starting-page>\n</topic>\n
